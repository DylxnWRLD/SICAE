{
  "info": {
    "name": "SICAE - User/Auth Service",
    "description": "Colección para probar el microservicio user de SICAE: login, catálogos, perfil, registro, edición y cambio de estatus.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "idUsuario",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuario\": \"admin\",\n  \"contrasena\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/autenticacion/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "autenticacion",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login exitoso', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "let json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "}",
                  "if (json.idUsuario) {",
                  "    pm.collectionVariables.set('idUsuario', json.idUsuario);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Catalogos",
      "item": [
        {
          "name": "Listar roles",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/usuarios/catalogos/roles",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "usuarios",
                "catalogos",
                "roles"
              ]
            }
          }
        },
        {
          "name": "Listar tipos de usuario",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/usuarios/catalogos/tipos-usuario",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "usuarios",
                "catalogos",
                "tipos-usuario"
              ]
            }
          }
        },
        {
          "name": "Listar programas educativos",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/usuarios/catalogos/programas-educativos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "usuarios",
                "catalogos",
                "programas-educativos"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Usuarios",
      "item": [
        {
          "name": "Ver perfil",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/usuarios/{{idUsuario}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "usuarios",
                "{{idUsuario}}"
              ]
            }
          }
        },
        {
          "name": "Registrar usuario",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idRol\": 2,\n  \"idTipoUsuario\": 1,\n  \"idProgramaEducativo\": 1,\n  \"nombre\": \"Carlos\",\n  \"apellidoPaterno\": \"Ramirez\",\n  \"apellidoMaterno\": \"Lopez\",\n  \"usuario\": \"carlos.ramirez\",\n  \"contrasena\": \"Carlos123\",\n  \"correo\": \"carlos.ramirez@uv.mx\",\n  \"telefono\": \"2281234567\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/usuarios",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "usuarios"
              ]
            }
          }
        },
        {
          "name": "Editar usuario",
          "request": {
            "method": "PUT",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idRol\": 2,\n  \"idTipoUsuario\": 1,\n  \"idProgramaEducativo\": 1,\n  \"nombre\": \"Carlos Alberto\",\n  \"apellidoPaterno\": \"Ramirez\",\n  \"apellidoMaterno\": \"Lopez\",\n  \"correo\": \"carlos.alberto@uv.mx\",\n  \"telefono\": \"2287654321\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/usuarios/{{idUsuario}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "usuarios",
                "{{idUsuario}}"
              ]
            }
          }
        },
        {
          "name": "Cambiar estatus usuario",
          "request": {
            "method": "PATCH",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"activo\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/usuarios/{{idUsuario}}/estatus",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "usuarios",
                "{{idUsuario}}",
                "estatus"
              ]
            }
          }
        }
      ]
    }
  ]
}