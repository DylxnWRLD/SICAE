{
  "info": {
    "name": "SICAE - Microservicios de vehículos",
    "description": "Colección para probar el microservicio de vehículos de SICAE. El token se obtiene del microservicio de autenticación (puerto 8081) y se usa para las peticiones de vehículos (puerto 8082).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Autenticación - Obtener Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login exitoso', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "let json = pm.response.json();",
              "if (json.token) {",
              "    pm.collectionVariables.set('token', json.token);",
              "    console.log('Token guardado:', json.token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"usuario\": \"admin\",\n  \"contrasena\": \"admin123\"\n}"
        },
        "url": {
          "raw": "http://localhost:8081/api/autenticacion/login",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8081",
          "path": [
            "api",
            "autenticacion",
            "login"
          ]
        }
      }
    },
    {
      "name": "2. Vehículos",
      "item": [
        {
          "name": "Obtener vehículos por usuario",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "url": {
              "raw": "http://localhost:8082/api/vehiculos/1",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8082",
              "path": [
                "api",
                "vehiculos",
                "1"
              ]
            }
          }
        },
        {
          "name": "Registrar vehículo",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idUsuario\": 1,\n  \"claveVehiculo\": \"TEST001\",\n  \"idModelo\": 1,\n  \"placa\": \"TEST01\",\n  \"color\": \"Rojo\",\n  \"anio\": 2022,\n  \"descripcion\": \"Vehículo de prueba\",\n  \"estatus\": true\n}"
            },
            "url": {
              "raw": "http://localhost:8082/api/vehiculos/registrarse",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8082",
              "path": [
                "api",
                "vehiculos",
                "registrarse"
              ]
            }
          }
        },
        {
          "name": "Editar vehículo",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idVehiculo\": 1,\n  \"idUsuario\": 1,\n  \"idModelo\": 1,\n  \"placa\": \"EDIT01\",\n  \"color\": \"Azul\",\n  \"anio\": 2023,\n  \"descripcion\": \"Vehículo editado\"\n}"
            },
            "url": {
              "raw": "http://localhost:8082/api/vehiculos/editar",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8082",
              "path": [
                "api",
                "vehiculos",
                "editar"
              ]
            }
          }
        },
        {
          "name": "Cambiar estatus del vehículo",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idUsuario\": 1,\n  \"idVehiculo\": 1,\n  \"estatus\": false\n}"
            },
            "url": {
              "raw": "http://localhost:8082/api/vehiculos/editarestatus",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8082",
              "path": [
                "api",
                "vehiculos",
                "editarestatus"
              ]
            }
          }
        }
      ]
    }
  ]
}